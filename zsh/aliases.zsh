# --- Git Aliases ---
alias g="git"
alias gs="git status"
alias ga="git add"
alias gc="git commit -v"
alias gp="git push"
alias gl="git pull"
alias gd="git diff"
alias gco="git checkout"
alias gb="git branch"

# --- Common Directory Navigation ---
alias ..="cd .."
alias ...="cd ../.."
alias ....="cd ../../.."
alias .....="cd ../../../.."
alias l="ls -lah"
alias ll="ls -l"
alias la="ls -A"

# --- Developer Utils ---
alias reload="source ~/.zshrc"
alias cls="clear"
alias zshconfig="nano ~/.zshrc"
alias dotfiles="cd ~/projects/dotfiles"

# --- Docker (Optional) ---
alias d="docker"
alias dc="docker-compose"
